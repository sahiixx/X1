# NOWHERE.ai frontend (Vite) — build-time configuration.
# Copy to `.env` and edit. Vite only reads vars prefixed with VITE_.
#
# .env is gitignored — never commit real values.

# The live Fixfiz backend URL. READ AT BUILD TIME and baked into the bundle,
# so set it BEFORE `npm run build` and rebuild whenever the backend URL
# changes. For local dev against the WSL backend:
VITE_API_URL=http://localhost:8001
# For production (Cloudflare Pages build env):
# VITE_API_URL=https://<your-backend>.onrender.com